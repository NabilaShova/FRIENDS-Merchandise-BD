# ─── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="FRIENDS Merchandise BD"

# ─── Database (optional — any PostgreSQL via Prisma) ───────────────────
# Leave BLANK to run on the zero-setup in-memory store.
# Set it to switch the whole app to a shared, durable Postgres database.
#   • Neon:     postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#   • Supabase: use the "Direct connection" string (port 5432) for db push/seed
#   • Render:   the database's Internal/External Connection String
# After setting it:  npx prisma db push && npm run db:seed
DATABASE_URL=""

# ─── Persistent file store (alternative to a database) ─────────────────
# If set (and DATABASE_URL is blank), the in-memory store is saved here as
# JSON so it survives restarts (e.g. a Render disk mounted at /var/data).
DATA_DIR=""

# ─── Admin access ──────────────────────────────────────────────────────
# Password for the /admin panel login (defaults to "friends-admin" if unset).
ADMIN_PASSWORD="friends-admin"

# ─── Auth (NextAuth) ───────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Media (Cloudinary) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Payments ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
SSLCOMMERZ_IS_LIVE="false"

# ─── AI (Admin content generation) ─────────────────────────────────────
OPENAI_API_KEY=""
